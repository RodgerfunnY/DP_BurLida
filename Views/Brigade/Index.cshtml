@model IEnumerable<DP_BurLida.Data.ModelsData.BrigadeModelData>

@{
    ViewData["Title"] = "Бригады";
}

<h1>Бригады</h1>

<p>
    <a asp-action="Create" class="btn btn-outline-success">
        <i class="fas fa-people-group me-1"></i> Добавить бригаду
    </a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Название бригады</th>
            <th>Техника бригады</th>
            <th>Ответственный</th>
            <th>Доп. информация</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.NameBrigade)</td>
            <td>@Html.DisplayFor(modelItem => item.Technic)</td>
            <td>
                @if (item.ResponsibleUser != null)
                {
                    @($"{item.ResponsibleUser.Name} {item.ResponsibleUser.Surname}")
                }
                else
                {
                    <span class="text-muted">Не назначен</span>
                }
            </td>
            <td>@Html.DisplayFor(modelItem => item.Info)</td>
            <td class="text-nowrap">
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning me-1">
                    <i class="fas fa-pen me-1"></i> Редактировать
                </a>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1">
                    <i class="fas fa-eye me-1"></i> Подробности
                </a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                    <i class="fas fa-trash me-1"></i> Удалить
                </a>
            </td>
        </tr>
}
    </tbody>
</table>
