@model List<DP_BurLida.Data.ModelsData.OrderModelData>

@{
    ViewData["Title"] = "Заказы на день";
    var selectedDate = ViewBag.SelectedDate as DateTime?;
    var calendarType = (ViewBag.CalendarType as string ?? "drilling").ToLowerInvariant();
    var isMontage = calendarType == "montage";
}

<div class="container">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2>Работы на @selectedDate?.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("ru-RU"))</h2>
                    <p class="text-muted">Заказы с назначенной датой выполнения работ</p>
                </div>
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    Назад к календарю
                </a>
            </div>

            @if (Model.Any())
            {
                <div class="row">
                    @foreach (var order in Model)
                    {
                        <div class="col-md-6 col-lg-4 mb-3">
                            @{
                                var brigadeClass = order.BrigadeStatus switch
                                {
                                    "приоритет нашей бригаде" => "border-danger",
                                    "Наша бригада" => "border-success",
                                    "Возможно подрядчики" => "border-warning",
                                    _ => string.Empty
                                };
                            }
                            <div class="card @brigadeClass">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">@order.NameClient @order.SurnameClient</h5>
                                </div>
                                <div class="card-body">
                                    <p class="card-text mb-1">
                                        <strong>@(isMontage ? "Дата обустройства:" : "Дата бурения:")</strong>
                                        @{
                                            var workDate = isMontage ? order.ArrangementDate : order.WorkDate;
                                        }
                                        <span class="text-success fw-bold">@workDate?.ToString("dd.MM.yyyy")</span>
                                    </p>

                                    <p class="card-text mb-1">
                                        <strong>Бригада:</strong>
                                        @if (isMontage && order.ArrangementBrigade != null)
                                        {
                                            @($"{order.ArrangementBrigade.NameBrigade} (Ответственный: {order.ArrangementBrigade.ResponsibleUser?.FullName ?? "Не назначен"})")
                                        }
                                        else if (!isMontage && order.DrillingBrigade != null)
                                        {
                                            @($"{order.DrillingBrigade.NameBrigade} (Ответственный: {order.DrillingBrigade.ResponsibleUser?.FullName ?? "Не назначен"})")
                                        }
                                        else
                                        {
                                            @:Не назначена
                                        }
                                    </p>

                                    <p class="card-text mb-1">
                                        <strong>Адрес:</strong> @order.City
                                    </p>

                                    <p class="card-text mb-1">
                                        <strong>Координаты:</strong> @(string.IsNullOrEmpty(order.Coordinates) ? "Не указаны" : order.Coordinates)
                                    </p>

                                    <p class="card-text mb-1">
                                        <strong>Диаметр:</strong> @order.Diameter мм
                                    </p>
                                    <p class="card-text mb-1">
                                        <strong>Цена за метр:</strong> @order.PricePerMeter руб.
                                    </p>
                                    <p class="card-text mb-1">
                                        <strong>Насос:</strong> @order.Pump
                                    </p>
                                    <p class="card-text mb-1">
                                        <strong>Обустройство:</strong> @order.Arrangement
                                    </p>
                                    <p class="card-text mb-1">
                                        <strong>Комментарий:</strong> @order.Info
                                    </p>
                                    <p class="card-text mb-1">
                                        <strong>Итого за бурение скважины:</strong> @(string.IsNullOrEmpty(order.TotalDrillingAmount) ? "Не указано" : order.TotalDrillingAmount)
                                    </p>
                                    <p class="card-text mb-1">
                                        <strong>Итого за обустройство:</strong> @(string.IsNullOrEmpty(order.TotalArrangementAmount) ? "Не указано" : order.TotalArrangementAmount)
                                    </p>
                                    <p class="card-text mb-1">
                                        <strong>Менеджер:</strong> @(string.IsNullOrEmpty(order.CreatedBy) ? "Не указано" : order.CreatedBy)
                                    </p>
                                    <p class="card-text mb-1">
                                        <strong>Телефон:</strong> @order.Phone
                                    </p>
                                    @if (!string.IsNullOrEmpty(order.Status))
                                    {
                                        <p class="card-text mb-1">
                                            <strong>Статус:</strong> 
                                            <span class="badge @(order.Status switch {
                                                "Ожидание" => "bg-warning",
                                                "Бурение" => "bg-primary", 
                                                "Обустройство" => "bg-info",
                                                "Ремонт" => "bg-danger",
                                                "Завершен" => "bg-success",
                                                "Отдали подрядчикам" => "bg-dark",
                                                _ => "bg-secondary"
                                            })">@order.Status</span>
                                        </p>
                                    }
                                    <p class="card-text mb-1">
                                        <strong>Чья бригада:</strong> @(string.IsNullOrEmpty(order.BrigadeStatus) ? "Не указано" : order.BrigadeStatus)
                                    </p>
                                    <p class="card-text mb-1">
                                        <strong>Дата создания:</strong> @order.CreationTimeData.ToString("dd.MM.yyyy HH:mm")
                                    </p>
                                </div>
                                <div class="card-footer">
                                    <a href="@Url.Action("Details", "Order", new { id = order.Id })" class="btn btn-info btn-sm">
                                        Подробнее
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <h4>На этот день работ не запланировано</h4>
                    <p>На выбранную дату не назначено ни одной работы. Заказы без назначенной даты работы не отображаются в календаре.</p>
                    <a href="@Url.Action("Create", "Order")" class="btn btn-success">
                        Создать новый заказ
                    </a>
                </div>
            }
        </div>
    </div>
</div>
