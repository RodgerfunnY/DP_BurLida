@model DP_BurLida.Models.CalendarViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Календарь заказов";
    var ru = CultureInfo.GetCultureInfo("ru-RU");
}

<div class="container-fluid calendar-page">
    <style>
        /* Цветовая схема для пометки "Чья бригада" с хорошей читаемостью текста */
        .order-item-priority {
            background-color: #ffebee;          /* очень светло-красный */
            border-left: 3px solid #d32f2f;     /* красная полоса */
            color: #b71c1c;                     /* тёмно-красный текст */
        }

        .order-item-ours {
            background-color: #e8f5e9;          /* очень светло-зелёный */
            border-left: 3px solid #2e7d32;     /* зелёная полоса */
            color: #1b5e20;                     /* тёмно-зелёный текст */
        }

        .order-item-maybe-contractors {
            background-color: #fffde7;          /* очень светло-жёлтый */
            border-left: 3px solid #f9a825;     /* жёлтая полоса */
            color: #5d4037;                     /* тёмно-коричневый текст */
        }

        .order-item-priority small,
        .order-item-ours small,
        .order-item-maybe-contractors small {
            color: inherit;                     /* сохраняем контрастный цвет текста */
        }

        .list-group-item-priority {
            background-color: #ffebee;
            border-left: 4px solid #d32f2f;
            color: #b71c1c;
        }

        .list-group-item-ours {
            background-color: #e8f5e9;
            border-left: 4px solid #2e7d32;
            color: #1b5e20;
        }

        .list-group-item-maybe-contractors {
            background-color: #fffde7;
            border-left: 4px solid #f9a825;
            color: #5d4037;
        }

        /* В ячейках сетки на десктопе — одна строка; на телефоне стили в site.css + горизонтальный скролл */
        @@media (min-width: 992px) {
            .orders-container .order-item {
                display: block;
                padding: 2px 4px;
                margin-bottom: 2px;
                font-size: 0.8rem;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
                max-width: 110px;
                box-sizing: border-box;
            }
        }

        .unscheduled-card-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 8px;
        }

        .unscheduled-card-actions {
            display: inline-flex;
            gap: 6px;
            flex-shrink: 0;
        }

        .unscheduled-card-actions .btn {
            width: 28px;
            height: 28px;
            padding: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .calendar-main-title {
            font-size: clamp(1.15rem, 4.2vw, 1.65rem);
            line-height: 1.25;
        }

        .calendar-mobile-week-day {
            cursor: pointer;
            background: #fff;
        }

        .calendar-mobile-week-day.other-month {
            opacity: 0.72;
        }

        .calendar-mobile-week-order {
            display: block;
            font-size: 0.78rem;
            line-height: 1.25;
            word-break: break-word;
        }

        .calendar-mobile-week-order.mobile-order-priority {
            background-color: #ffebee;
            border-left: 4px solid #d32f2f;
            color: #b71c1c;
        }

        .calendar-mobile-week-order.mobile-order-ours {
            background-color: #e8f5e9;
            border-left: 4px solid #2e7d32;
            color: #1b5e20;
        }

        .calendar-mobile-week-order.mobile-order-maybe {
            background-color: #fffde7;
            border-left: 4px solid #f9a825;
            color: #5d4037;
        }

        .calendar-mobile-week-order.mobile-order-default {
            background-color: #f1f3f5;
            border-left: 4px solid #90a4ae;
            color: #212529;
        }

        .calendar-day-drop-hover {
            outline: 2px dashed #0d6efd !important;
            outline-offset: -3px;
            background-color: #e7f1ff !important;
        }
    </style>

    <ul class="nav nav-tabs mb-3 flex-nowrap overflow-x-auto pb-1 calendar-nav-tabs">
                <li class="nav-item text-nowrap">
                    <a class="nav-link @(Model.CalendarType == "drilling" ? "active" : "")"
                       href="@Url.Action("Index", new { year = Model.Year, month = Model.Month, type = "drilling" })">
                        График бурения
                    </a>
                </li>
                <li class="nav-item text-nowrap">
                    <a class="nav-link @(Model.CalendarType == "montage" ? "active" : "")"
                       href="@Url.Action("Index", new { year = Model.Year, month = Model.Month, type = "montage" })">
                        Монтажный график
                    </a>
                </li>
                <li class="nav-item text-nowrap">
                    <a class="nav-link @(Model.CalendarType == "contractors" ? "active" : "")"
                       href="@Url.Action("Index", new { year = Model.Year, month = Model.Month, type = "contractors" })">
                        <span class="d-md-none">Подрядчики</span>
                        <span class="d-none d-md-inline">Календарь подрядчиков</span>
                    </a>
                </li>
    </ul>

    <div class="d-flex flex-column flex-lg-row justify-content-lg-between align-items-lg-start gap-3 mb-3">
        <div class="flex-grow-1 min-w-0">
            <h2 class="calendar-main-title mb-1 fw-semibold">@Model.CalendarTitle — @Model.MonthName @Model.Year</h2>
            <p class="text-muted small mb-0 d-none d-lg-block">Заказы по дате выполнения работ.</p>
            <p class="text-muted small mb-0 d-lg-none">Неделя — дни столбиком; справа — заявки без даты. Листайте недели стрелками.</p>
        </div>
        <div class="btn-group calendar-month-nav w-100 w-lg-auto flex-wrap" role="group">
            <a href="@Url.Action("Index", new { year = Model.Year, month = Model.Month - 1, type = Model.CalendarType })"
               class="btn btn-primary btn-sm @(Model.Month == 1 ? "disabled" : "")">
                ← Месяц
            </a>
            <a href="@Url.Action("Index", new { year = DateTime.Now.Year, month = DateTime.Now.Month, type = Model.CalendarType })"
               class="btn btn-secondary btn-sm">
                Сейчас
            </a>
            <a href="@Url.Action("Index", new { year = Model.Year, month = Model.Month + 1, type = Model.CalendarType })"
               class="btn btn-primary btn-sm @(Model.Month == 12 ? "disabled" : "")">
                Месяц →
            </a>
        </div>
    </div>

    <div class="row g-2 calendar-layout-row">
        <div class="col-12 col-lg-9 calendar-main-column">
            @{
                var wkIdx = Model.MobileWeekIndex;
                var wkCount = Math.Max(1, Model.WeekCount);
                var weekDays = Model.Days.Skip(wkIdx * 7).Take(7).ToList();
            }
            <div class="d-lg-none calendar-mobile-week-wrap mb-1">
                <div class="d-flex align-items-center justify-content-between gap-1 mb-2">
                    @if (wkIdx > 0)
                    {
                        <a class="btn btn-sm btn-outline-primary"
                           href="@Url.Action("Index", new { year = Model.Year, month = Model.Month, type = Model.CalendarType, mw = wkIdx - 1 })">← нед</a>
                    }
                    else
                    {
                        <span class="btn btn-sm btn-outline-secondary disabled opacity-50">← нед</span>
                    }
                    <span class="small fw-semibold text-center px-1 flex-grow-1 text-truncate">
                        @if (weekDays.Count > 0)
                        {
                            @weekDays[0].Date.ToString("dd.MM", ru)<text> — </text>@weekDays[^1].Date.ToString("dd.MM", ru)
                        }
                    </span>
                    @if (wkIdx < wkCount - 1)
                    {
                        <a class="btn btn-sm btn-outline-primary"
                           href="@Url.Action("Index", new { year = Model.Year, month = Model.Month, type = Model.CalendarType, mw = wkIdx + 1 })">нед →</a>
                    }
                    else
                    {
                        <span class="btn btn-sm btn-outline-secondary disabled opacity-50">нед →</span>
                    }
                </div>
                <div class="calendar-mobile-week-column">
                    @foreach (var day in weekDays)
                    {
                        <div class="calendar-day calendar-mobile-week-day @(day.IsCurrentMonth ? "current-month" : "other-month") @(day.IsToday ? "today" : "") @(day.HasOrders ? "has-orders" : "")"
                             data-date="@day.Date.ToString("yyyy-MM-dd")">
                            <div class="d-flex justify-content-between align-items-baseline gap-1 mb-1">
                                <span class="fw-bold text-capitalize" style="font-size:0.82rem;">@ru.DateTimeFormat.GetAbbreviatedDayName(day.Date.DayOfWeek)</span>
                                <span class="text-muted" style="font-size:0.75rem;">@day.Date.ToString("d MMM", ru)</span>
                            </div>
                            @if (day.HasOrders)
                            {
                                <div class="d-flex flex-column gap-1 mt-1">
                                    @foreach (var order in day.Orders)
                                    {
                                        var oClass = order.BrigadeStatus switch
                                        {
                                            "приоритет нашей бригаде" => "mobile-order-priority",
                                            "Наша бригада" => "mobile-order-ours",
                                            "Возможно подрядчики" => "mobile-order-maybe",
                                            _ => "mobile-order-default"
                                        };
                                        <a href="@Url.Action("Details", "Order", new { id = order.Id })"
                                           class="calendar-mobile-week-order @oClass rounded-2 p-2 text-decoration-none">
                                            <span class="fw-semibold">@(string.IsNullOrEmpty(order.City) ? "Заявка" : order.City)</span>
                                            @if (!string.IsNullOrEmpty(order.Info))
                                            {
                                                <span class="d-block text-muted mt-1" style="font-size:0.72rem;">@order.Info</span>
                                            }
                                            @if (!string.IsNullOrEmpty(order.Status))
                                            {
                                                <span class="badge mt-1 @(order.Status switch {
                                                    "Ожидание" => "bg-warning text-dark",
                                                    "Бурение" => "bg-primary",
                                                    "Обустройство" => "bg-info",
                                                    "Ремонт" => "bg-danger",
                                                    "Завершен" => "bg-success",
                                                    "Отдали подрядчикам" => "bg-dark",
                                                    _ => "bg-secondary"
                                                })" style="font-size:0.65rem;">@order.Status</span>
                                            }
                                        </a>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-muted" style="font-size:0.72rem;">Нет заявок</div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="d-none d-lg-block calendar-desktop-grid-wrap">
            <div class="calendar-scroll-outer mb-2 mb-lg-0">
            <div class="calendar-container calendar-scroll-inner">
                <div class="calendar-header">
                    <div class="calendar-day-header">Пн</div>
                    <div class="calendar-day-header">Вт</div>
                    <div class="calendar-day-header">Ср</div>
                    <div class="calendar-day-header">Чт</div>
                    <div class="calendar-day-header">Пт</div>
                    <div class="calendar-day-header">Сб</div>
                    <div class="calendar-day-header">Вс</div>
                </div>

                <div class="calendar-grid">
                    @for (int i = 0; i < Model.Days.Count; i += 7)
                    {
                        <div class="calendar-week">
                            @for (int j = 0; j < 7 && (i + j) < Model.Days.Count; j++)
                            {
                                var day = Model.Days[i + j];
                                <div class="calendar-day @(day.IsCurrentMonth ? "current-month" : "other-month") @(day.IsToday ? "today" : "") @(day.HasOrders ? "has-orders" : "")"
                                     data-date="@day.Date.ToString("yyyy-MM-dd")">
                                    <div class="day-number">@day.Day</div>
                                    @if (day.HasOrders)
                                    {
                                        <div class="orders-container">
                                            @foreach (var order in day.Orders.Take(3))
                                            {
                                                var dateText = Model.CalendarType == "montage"
                                                    ? order.ArrangementDate?.ToString("dd.MM.yyyy")
                                                    : order.WorkDate?.ToString("dd.MM.yyyy");
                                                var brigadeClass = order.BrigadeStatus switch
                                                {
                                                    "приоритет нашей бригаде" => "order-item-priority",
                                                    "Наша бригада" => "order-item-ours",
                                                    "Возможно подрядчики" => "order-item-maybe-contractors",
                                                    _ => string.Empty
                                                };
                                                <div class="order-item @brigadeClass" title="@order.City - @order.Info - @order.NameClient @order.SurnameClient - @dateText">
                                                    <small>@order.City</small>
                                                    @if (!string.IsNullOrEmpty(order.Status))
                                                    {
                                                        <br />
                                                        <small class="badge @(order.Status switch {
                                                            "Ожидание" => "bg-warning",
                                                            "Бурение" => "bg-primary",
                                                            "Обустройство" => "bg-info",
                                                            "Ремонт" => "bg-danger",
                                                            "Завершен" => "bg-success",
                                                            "Отдали подрядчикам" => "bg-dark",
                                                            _ => "bg-secondary"
                                                        }) badge-sm">@order.Status</small>
                                                    }
                                                </div>
                                            }
                                            @if (day.Orders.Count > 3)
                                            {
                                                <div class="more-orders">
                                                    <small>+@(day.Orders.Count - 3) еще</small>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
            </div>
            </div>

        </div>

        <div class="col-12 col-lg-3 calendar-unscheduled-column">
            <h5 class="mb-2 mb-lg-3 calendar-unscheduled-heading">Без даты</h5>
            @if (Model.UnscheduledOrders != null && Model.UnscheduledOrders.Any())
            {
                <p class="text-muted small">Перетащи карточку на нужный день календаря.</p>
                <div class="list-group small">
                    @foreach (var order in Model.UnscheduledOrders.OrderByDescending(o => o.CreationTimeData).ThenByDescending(o => o.Id))
                    {
                        var brigadeClass = order.BrigadeStatus switch
                        {
                            "приоритет нашей бригаде" => "list-group-item-priority",
                            "Наша бригада" => "list-group-item-ours",
                            "Возможно подрядчики" => "list-group-item-maybe-contractors",
                            _ => string.Empty
                        };
                        <div class="list-group-item list-group-item-action mb-2 order-card-draggable @brigadeClass"
                             draggable="true"
                             data-order-id="@order.Id"
                             title="@order.Info @(string.IsNullOrEmpty(order.City) ? "" : " - " + order.City)">
                            <div class="unscheduled-card-header">
                                <div class="flex-grow-1">
                                    <div class="fw-semibold">@order.Info</div>
                                </div>
                                <div class="unscheduled-card-actions" draggable="false">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary unscheduled-open-details"
                                            data-order-id="@order.Id"
                                            title="Подробности"
                                            draggable="false">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary unscheduled-open-comments"
                                            data-order-id="@order.Id"
                                            title="Комментарии"
                                            draggable="false">
                                        <i class="fas fa-comments"></i>
                                    </button>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(order.City))
                            {
                                <div class="text-muted small">@order.City</div>
                            }
                            @if (!string.IsNullOrEmpty(order.Status))
                            {
                                <div class="mt-1">
                                    <span class="badge @(order.Status switch {
                                        "Ожидание" => "bg-warning",
                                        "Бурение" => "bg-primary",
                                        "Обустройство" => "bg-info",
                                        "Ремонт" => "bg-danger",
                                        "Завершен" => "bg-success",
                                        "Отдали подрядчикам" => "bg-dark",
                                        _ => "bg-secondary"
                                    })">@order.Status</span>
                                </div>
                            }
                        </div>

                        <div class="collapse mb-2" id="unscheduled-collapse-@order.Id" data-order-id="@order.Id">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-2">
                                    <ul class="nav nav-pills mb-2" id="unscheduled-tabs-@order.Id" role="tablist">
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link active py-1 px-2"
                                                    id="unscheduled-details-tab-@order.Id"
                                                    data-bs-toggle="tab"
                                                    data-bs-target="#unscheduled-details-@order.Id"
                                                    type="button" role="tab"
                                                    aria-controls="unscheduled-details-@order.Id"
                                                    aria-selected="true">
                                                Подробности
                                            </button>
                                        </li>
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link py-1 px-2"
                                                    id="unscheduled-comments-tab-@order.Id"
                                                    data-bs-toggle="tab"
                                                    data-bs-target="#unscheduled-comments-@order.Id"
                                                    type="button" role="tab"
                                                    aria-controls="unscheduled-comments-@order.Id"
                                                    aria-selected="false">
                                                Комментарии
                                            </button>
                                        </li>
                                    </ul>
                                    <div class="tab-content">
                                        <div class="tab-pane fade show active" id="unscheduled-details-@order.Id" role="tabpanel" aria-labelledby="unscheduled-details-tab-@order.Id">
                                            <div class="text-muted small">Нажми “Подробности” чтобы загрузить.</div>
                                        </div>
                                        <div class="tab-pane fade" id="unscheduled-comments-@order.Id" role="tabpanel" aria-labelledby="unscheduled-comments-tab-@order.Id">
                                            <div class="text-muted small">Нажми “Комментарии” чтобы загрузить.</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">
                    @if (Model.CalendarType == "montage")
                    {
                        @:Все заявки имеют дату обустройства.
                    }
                    else
                    {
                        @:Все заявки имеют дату бурения.
                    }
                </p>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Переход к списку заказов за день по клику
            $('.calendar-day').click(function (e) {
                if ($(e.target).closest('a[href]').length) {
                    return;
                }
                var date = $(this).data('date');
                if (date) {
                    var type = '@Model.CalendarType';
                    window.location.href = '@Url.Action("DayDetails")' + '?date=' + date + '&type=' + type;
                }
            });

            // Drag & Drop заявок на календарь
            var draggedOrderId = null;
            var draggedFromCard = false;

            $('.order-card-draggable').on('dragstart', function (e) {
                draggedOrderId = $(this).data('order-id');
                draggedFromCard = true;
            });
            $('.order-card-draggable').on('dragend', function () {
                setTimeout(function () { draggedFromCard = false; }, 0);
            });

            $('.calendar-day').on('dragover', function (e) {
                e.preventDefault();
                $(this).addClass('calendar-day-drop-hover');
            });

            $('.calendar-day').on('dragleave', function () {
                $(this).removeClass('calendar-day-drop-hover');
            });

            $('.calendar-day').on('drop', function (e) {
                e.preventDefault();
                $(this).removeClass('calendar-day-drop-hover');

                var date = $(this).data('date');
                var orderId = draggedOrderId;
                var type = '@Model.CalendarType';

                if (!date || !orderId) {
                    return;
                }

                $.post('@Url.Action("UpdateWorkDate", "Calendar")', { orderId: orderId, newDate: date, calendarType: type })
                    .done(function () {
                        window.location.reload();
                    })
                    .fail(function () {
                        alert('Не удалось сохранить дату.');
                    });
            });

            function ensureCollapseShown(orderId) {
                var el = document.getElementById('unscheduled-collapse-' + orderId);
                if (!el || !window.bootstrap) return null;
                var c = bootstrap.Collapse.getOrCreateInstance(el, { toggle: false });
                c.show();
                return el;
            }

            function showTab(orderId, tabName) {
                if (!window.bootstrap) return;
                var targetId = (tabName === 'comments')
                    ? '#unscheduled-comments-' + orderId
                    : '#unscheduled-details-' + orderId;
                var trigger = document.querySelector('[data-bs-toggle="tab"][data-bs-target="' + targetId + '"]');
                if (!trigger) return;
                var tab = new bootstrap.Tab(trigger);
                tab.show();
            }

            function loadDetails(orderId) {
                var container = document.getElementById('unscheduled-details-' + orderId);
                if (!container) return;
                if (container.dataset.loaded === '1') return;
                container.innerHTML = '<div class="text-muted small">Загрузка...</div>';
                fetch('@Url.Action("QuickDetailsPartial", "Order")' + '?id=' + orderId, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(function (r) { return r.ok ? r.text() : Promise.reject(); })
                    .then(function (html) { container.innerHTML = html; container.dataset.loaded = '1'; })
                    .catch(function () { container.innerHTML = '<div class="text-danger small">Не удалось загрузить подробности.</div>'; });
            }

            function loadComments(orderId, returnHash) {
                var container = document.getElementById('unscheduled-comments-' + orderId);
                if (!container) return;
                if (container.dataset.loaded === '1') return;
                container.innerHTML = '<div class="text-muted small">Загрузка...</div>';
                var returnUrl = window.location.pathname + window.location.search + returnHash;
                fetch('@Url.Action("ListPartial", "OrderComment")' + '?orderId=' + orderId + '&returnUrl=' + encodeURIComponent(returnUrl), { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(function (r) { return r.ok ? r.text() : Promise.reject(); })
                    .then(function (html) { container.innerHTML = html; container.dataset.loaded = '1'; })
                    .catch(function () { container.innerHTML = '<div class="text-danger small">Не удалось загрузить комментарии.</div>'; });
            }

            function openUnscheduled(orderId, tabName) {
                ensureCollapseShown(orderId);
                showTab(orderId, tabName);
                if (tabName === 'comments') {
                    var hash = '#unscheduled-' + orderId + '-comments';
                    loadComments(orderId, hash);
                    window.location.hash = hash;
                } else {
                    var hash2 = '#unscheduled-' + orderId + '-details';
                    loadDetails(orderId);
                    window.location.hash = hash2;
                }
            }

            $('.unscheduled-open-details').on('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                var orderId = $(this).data('order-id');
                openUnscheduled(orderId, 'details');
            });

            $('.unscheduled-open-comments').on('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                var orderId = $(this).data('order-id');
                openUnscheduled(orderId, 'comments');
            });

            $('.order-card-draggable').on('click', function (e) {
                if (draggedFromCard) return;
                if ($(e.target).closest('.unscheduled-card-actions').length) return;
                var orderId = $(this).data('order-id');
                openUnscheduled(orderId, 'details');
            });

            if (window.location.hash && window.location.hash.startsWith('#unscheduled-')) {
                var m = window.location.hash.match(/^#unscheduled-(\d+)-(details|comments)$/);
                if (m) {
                    var orderId = parseInt(m[1]);
                    var tab = m[2];
                    openUnscheduled(orderId, tab);
                }
            }
        });
    </script>
}
