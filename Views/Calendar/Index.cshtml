@model DP_BurLida.Models.CalendarViewModel

@{
    ViewData["Title"] = "Календарь заказов";
}

<div class="container-fluid">
    <style>
        /* Цветовая схема для пометки "Чья бригада" с хорошей читаемостью текста */
        .order-item-priority {
            background-color: #ffebee;          /* очень светло-красный */
            border-left: 3px solid #d32f2f;     /* красная полоса */
            color: #b71c1c;                     /* тёмно-красный текст */
        }

        .order-item-ours {
            background-color: #e8f5e9;          /* очень светло-зелёный */
            border-left: 3px solid #2e7d32;     /* зелёная полоса */
            color: #1b5e20;                     /* тёмно-зелёный текст */
        }

        .order-item-maybe-contractors {
            background-color: #fffde7;          /* очень светло-жёлтый */
            border-left: 3px solid #f9a825;     /* жёлтая полоса */
            color: #5d4037;                     /* тёмно-коричневый текст */
        }

        .order-item-priority small,
        .order-item-ours small,
        .order-item-maybe-contractors small {
            color: inherit;                     /* сохраняем контрастный цвет текста */
        }

        .list-group-item-priority {
            background-color: #ffebee;
            border-left: 4px solid #d32f2f;
            color: #b71c1c;
        }

        .list-group-item-ours {
            background-color: #e8f5e9;
            border-left: 4px solid #2e7d32;
            color: #1b5e20;
        }

        .list-group-item-maybe-contractors {
            background-color: #fffde7;
            border-left: 4px solid #f9a825;
            color: #5d4037;
        }

        /* Компактное отображение заявок в ячейках календаря — адрес в одну строку */
        .orders-container .order-item {
            display: block;
            padding: 2px 4px;
            margin-bottom: 2px;
            font-size: 0.8rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 110px;          /* показываем часть адреса, даже если ячейка шире */
            box-sizing: border-box;
        }
    </style>
    <div class="row">
        <div class="col-md-9">
            <ul class="nav nav-tabs mb-3">
                <li class="nav-item">
                    <a class="nav-link @(Model.CalendarType == "drilling" ? "active" : "")"
                       href="@Url.Action("Index", new { year = Model.Year, month = Model.Month, type = "drilling" })">
                        График бурения
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(Model.CalendarType == "montage" ? "active" : "")"
                       href="@Url.Action("Index", new { year = Model.Year, month = Model.Month, type = "montage" })">
                        Монтажный график
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(Model.CalendarType == "contractors" ? "active" : "")"
                       href="@Url.Action("Index", new { year = Model.Year, month = Model.Month, type = "contractors" })">
                        Календарь подрядчиков
                    </a>
                </li>
            </ul>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h2>@Model.CalendarTitle - @Model.MonthName @Model.Year</h2>
                    <p class="text-muted mb-0">Заказы отображаются по дате выполнения работ</p>
                </div>
                <div class="btn-group" role="group">
                    <a href="@Url.Action("Index", new { year = Model.Year, month = Model.Month - 1, type = Model.CalendarType })" 
                       class="btn btn-primary @(Model.Month == 1 ? "disabled" : "")">
                        Предыдущий месяц
                    </a>
                    <a href="@Url.Action("Index", new { year = DateTime.Now.Year, month = DateTime.Now.Month, type = Model.CalendarType })" 
                       class="btn btn-secondary">
                        Текущий месяц
                    </a>
                    <a href="@Url.Action("Index", new { year = Model.Year, month = Model.Month + 1, type = Model.CalendarType })" 
                       class="btn btn-primary @(Model.Month == 12 ? "disabled" : "")">
                        Следующий месяц
                    </a>
                </div>
            </div>

            <div class="calendar-container">
                <div class="calendar-header">
                    <div class="calendar-day-header">Пн</div>
                    <div class="calendar-day-header">Вт</div>
                    <div class="calendar-day-header">Ср</div>
                    <div class="calendar-day-header">Чт</div>
                    <div class="calendar-day-header">Пт</div>
                    <div class="calendar-day-header">Сб</div>
                    <div class="calendar-day-header">Вс</div>
                </div>

                <div class="calendar-grid">
                    @for (int i = 0; i < Model.Days.Count; i += 7)
                    {
                        <div class="calendar-week">
                            @for (int j = 0; j < 7 && (i + j) < Model.Days.Count; j++)
                            {
                                var day = Model.Days[i + j];
                                <div class="calendar-day @(day.IsCurrentMonth ? "current-month" : "other-month") @(day.IsToday ? "today" : "") @(day.HasOrders ? "has-orders" : "")"
                                     data-date="@day.Date.ToString("yyyy-MM-dd")">
                                    <div class="day-number">@day.Day</div>
                                    @if (day.HasOrders)
                                    {
                                        <div class="orders-container">
                                            @foreach (var order in day.Orders.Take(3))
                                            {
                                                var dateText = Model.CalendarType == "montage"
                                                    ? order.ArrangementDate?.ToString("dd.MM.yyyy")
                                                    : order.WorkDate?.ToString("dd.MM.yyyy");
                                                var brigadeClass = order.BrigadeStatus switch
                                                {
                                                    "приоритет нашей бригаде" => "order-item-priority",
                                                    "Наша бригада" => "order-item-ours",
                                                    "Возможно подрядчики" => "order-item-maybe-contractors",
                                                    _ => string.Empty
                                                };
                                                <div class="order-item @brigadeClass" title="@order.City - @order.Info - @order.NameClient @order.SurnameClient - @dateText">
                                                    <small>@order.City</small>
                                                    @if (!string.IsNullOrEmpty(order.Status))
                                                    {
                                                        <br />
                                                        <small class="badge @(order.Status switch {
                                                            "Ожидание" => "bg-warning",
                                                            "Бурение" => "bg-primary",
                                                            "Обустройство" => "bg-info",
                                                            "Ремонт" => "bg-danger",
                                                            "Завершен" => "bg-success",
                                                            "Отдали подрядчикам" => "bg-dark",
                                                            _ => "bg-secondary"
                                                        }) badge-sm">@order.Status</small>
                                                    }
                                                </div>
                                            }
                                            @if (day.Orders.Count > 3)
                                            {
                                                <div class="more-orders">
                                                    <small>+@(day.Orders.Count - 3) еще</small>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-3 mt-4 mt-md-0">
            <h5 class="mb-3">Заявки без даты</h5>
            @if (Model.UnscheduledOrders != null && Model.UnscheduledOrders.Any())
            {
                <p class="text-muted small">Перетащи карточку на нужный день календаря.</p>
                <div class="list-group small">
                    @foreach (var order in Model.UnscheduledOrders.OrderBy(o => o.CreationTimeData))
                    {
                        var brigadeClass = order.BrigadeStatus switch
                        {
                            "приоритет нашей бригаде" => "list-group-item-priority",
                            "Наша бригада" => "list-group-item-ours",
                            "Возможно подрядчики" => "list-group-item-maybe-contractors",
                            _ => string.Empty
                        };
                        <div class="list-group-item list-group-item-action mb-2 order-card-draggable @brigadeClass"
                             draggable="true"
                             data-order-id="@order.Id"
                             title="@order.Info @(string.IsNullOrEmpty(order.City) ? "" : " - " + order.City)">
                            <div class="fw-semibold">@order.Info</div>
                            @if (!string.IsNullOrEmpty(order.City))
                            {
                                <div class="text-muted small">@order.City</div>
                            }
                            @if (!string.IsNullOrEmpty(order.Status))
                            {
                                <div class="mt-1">
                                    <span class="badge @(order.Status switch {
                                        "Ожидание" => "bg-warning",
                                        "Бурение" => "bg-primary",
                                        "Обустройство" => "bg-info",
                                        "Ремонт" => "bg-danger",
                                        "Завершен" => "bg-success",
                                        "Отдали подрядчикам" => "bg-dark",
                                        _ => "bg-secondary"
                                    })">@order.Status</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">
                    @if (Model.CalendarType == "montage")
                    {
                        @:Все заявки имеют дату обустройства.
                    }
                    else
                    {
                        @:Все заявки имеют дату бурения.
                    }
                </p>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Переход к списку заказов за день по клику
            $('.calendar-day').click(function () {
                var date = $(this).data('date');
                if (date) {
                    var type = '@Model.CalendarType';
                    window.location.href = '@Url.Action("DayDetails")' + '?date=' + date + '&type=' + type;
                }
            });

            // Drag & Drop заявок на календарь
            var draggedOrderId = null;

            $('.order-card-draggable').on('dragstart', function (e) {
                draggedOrderId = $(this).data('order-id');
            });

            $('.calendar-day').on('dragover', function (e) {
                e.preventDefault();
                $(this).addClass('calendar-day-drop-hover');
            });

            $('.calendar-day').on('dragleave', function () {
                $(this).removeClass('calendar-day-drop-hover');
            });

            $('.calendar-day').on('drop', function (e) {
                e.preventDefault();
                $(this).removeClass('calendar-day-drop-hover');

                var date = $(this).data('date');
                var orderId = draggedOrderId;
                var type = '@Model.CalendarType';

                if (!date || !orderId) {
                    return;
                }

                $.post('@Url.Action("UpdateWorkDate", "Calendar")', { orderId: orderId, newDate: date, calendarType: type })
                    .done(function () {
                        window.location.reload();
                    })
                    .fail(function () {
                        alert('Не удалось сохранить дату.');
                    });
            });
        });
    </script>
}
