@{
    ViewData["Title"] = "Главная страница";
    var stats = ViewBag.Statistics as dynamic;
    var ordersForMapJson = ViewBag.OrdersForMapJson as string ?? "[]";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <h1 class="text-center mb-4">Система управления заказами</h1>
            <p class="text-center">Добро пожаловать в систему управления заказами компании BurLida</p>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title text-warning">Ожидание</h5>
                    <h2 class="text-warning">@stats.WaitingOrders</h2>
                    <p class="card-text">заказов в ожидании</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title text-primary">В работе</h5>
                    <h2 class="text-primary">@stats.InWorkOrders</h2>
                    <p class="card-text">заказов выполняется</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title text-danger">Ремонт</h5>
                    <h2 class="text-danger">@stats.RepairOrders</h2>
                    <p class="card-text">заказов на ремонте</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title text-success">Завершено</h5>
                    <h2 class="text-success">@stats.CompletedOrders</h2>
                    <p class="card-text">заказов завершено</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card text-center">
                <div class="card-body">
                    <h4 class="card-title">Общее количество заказов</h4>
                    <h1 class="display-4 text-info">@stats.TotalOrders</h1>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Карта обслуживания</h5>
                    <div class="d-flex align-items-center gap-2">
                        <span class="me-2">Фильтр по статусу:</span>
                        <select id="statusFilter" class="form-select form-select-sm" style="width:auto;">
                            <option value="">Все</option>
                            <option value="Ожидание">Ожидание</option>
                            <option value="Бурение">Бурение</option>
                            <option value="Обустройство">Обустройство</option>
                            <option value="Ремонт">Ремонт</option>
                        </select>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div id="map" style="width: 100%; height: 500px;"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12 text-center">
            <p>Посетите наш <a href="https://burlida.by/" target="_blank" class="btn btn-outline-primary">официальный сайт</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://api-maps.yandex.ru/2.1/?apikey=4241305e-2e84-4c08-92f5-27f017cf2057&lang=ru_RU" type="text/javascript"></script>
    <script>
        const ordersForMap = @Html.Raw(ordersForMapJson);
        let ymapsMap;
        let allPlacemarks = [];

        function initMapYandex() {
            ymapsMap = new ymaps.Map("map", {
                center: [53.9, 27.55],
                zoom: 9
            });

            const statusPresets = {
                "Ожидание": "islands#orangeCircleIcon",
                "Ремонт": "islands#redCircleIcon",
                "Бурение": "islands#greenCircleIcon",
                "Обустройство": "islands#blueCircleIcon"
            };

            const points = [];

            ordersForMap.forEach(o => {
                if (!o.coordinates) return;
                const parts = o.coordinates.split(/[,\s]+/).map(x => parseFloat(x.replace(",", ".")));
                if (parts.length < 2 || isNaN(parts[0]) || isNaN(parts[1])) return;

                const coords = [parts[0], parts[1]];
                const preset = statusPresets[o.status] || "islands#grayCircleIcon";

                const placemark = new ymaps.Placemark(
                    coords,
                    {
                        balloonContent: `<strong>${o.nameClient ?? ""}</strong><br/>Статус: ${o.status ?? ""}`
                    },
                    {
                        preset: preset
                    }
                );

                placemark.orderStatus = o.status;

                ymapsMap.geoObjects.add(placemark);
                allPlacemarks.push(placemark);
                points.push(coords);
            });

            if (points.length > 0) {
                const bounds = ymaps.util.bounds.fromPoints(points);
                ymapsMap.setBounds(bounds, { checkZoomRange: true, zoomMargin: 20 });
            }

            const statusFilter = document.getElementById("statusFilter");
            if (statusFilter) {
                statusFilter.addEventListener("change", () => {
                    const value = statusFilter.value;
                    allPlacemarks.forEach(p => {
                        if (!value || p.orderStatus === value) {
                            if (!ymapsMap.geoObjects.contains(p)) {
                                ymapsMap.geoObjects.add(p);
                            }
                        } else {
                            if (ymapsMap.geoObjects.contains(p)) {
                                ymapsMap.geoObjects.remove(p);
                            }
                        }
                    });
                });
            }
        }

        if (window.ymaps) {
            ymaps.ready(initMapYandex);
        }
    </script>
}
