@{
    ViewData["Title"] = "Главная страница";
    var stats = ViewBag.Statistics as dynamic;
    var ordersForMapJson = ViewBag.OrdersForMapJson as string ?? "[]";
}

<div class="container-fluid">
    <style>
        .dashboard-card {
            border: none;
            border-radius: 1rem;
            box-shadow: 0 0.25rem 0.75rem rgba(15, 23, 42, 0.08);
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }

        .dashboard-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 0.75rem 1.5rem rgba(15, 23, 42, 0.18);
        }

        .dashboard-icon {
            width: 2.75rem;
            height: 2.75rem;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            margin-bottom: 0.5rem;
        }

        .dashboard-label {
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            font-weight: 600;
        }

        .dashboard-value {
            font-size: 1.75rem;
            font-weight: 700;
            line-height: 1;
        }

        @@media (max-width: 576px) {
            h1 {
                font-size: 1.5rem;
            }

            .dashboard-value {
                font-size: 1.4rem;
            }

            #map {
                height: 260px !important;
            }
        }

        @@media (max-width: 768px) {
            #map {
                height: 320px;
            }
        }
    </style>
    <div class="row">
        <div class="col-12">
            <h1 class="text-center mb-4">Система управления заказами</h1>
            <p class="text-center">Добро пожаловать в систему управления заказами компании BurLida</p>
        </div>
    </div>

    @if (!(User.IsInRole("DrillingMaster") || User.IsInRole("MountingMaster")))
    {
        <div class="row g-3 mb-4">
            <div class="col-12 col-sm-6 col-lg">
                <div class="card dashboard-card text-center bg-white">
                    <div class="card-body">
                        <div class="dashboard-label text-warning">Ожидание</div>
                        <div class="dashboard-value text-warning">@stats.WaitingOrders</div>
                        <div class="text-muted small mt-1">заказов в ожидании</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg">
                <div class="card dashboard-card text-center bg-white">
                    <div class="card-body">
                        <div class="dashboard-label text-primary">Бурение</div>
                        <div class="dashboard-value text-primary">@stats.DrillingOrders</div>
                        <div class="text-muted small mt-1">заказов на бурение</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg">
                <div class="card dashboard-card text-center bg-white">
                    <div class="card-body">
                        <div class="dashboard-label text-info">Обустройство</div>
                        <div class="dashboard-value text-info">@stats.ArrangementOrders</div>
                        <div class="text-muted small mt-1">заказов на обустройство</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg">
                <div class="card dashboard-card text-center bg-white">
                    <div class="card-body">
                        <div class="dashboard-label text-dark">Подрядчики</div>
                        <div class="dashboard-value text-dark">@stats.ContractorsOrders</div>
                        <div class="text-muted small mt-1">заказов у подрядчиков</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg">
                <div class="card dashboard-card text-center bg-white">
                    <div class="card-body">
                        <div class="dashboard-label text-danger">Ремонт</div>
                        <div class="dashboard-value text-danger">@stats.RepairOrders</div>
                        <div class="text-muted small mt-1">заказов на ремонте</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Карта обслуживания</h5>
                        <div class="d-flex align-items-center gap-2">
                            <span class="me-2">Фильтр по статусу:</span>
                            <select id="statusFilter" class="form-select form-select-sm" style="width:auto;">
                                <option value="">Все</option>
                                <option value="Ожидание">Ожидание</option>
                                <option value="Бурение">Бурение</option>
                                <option value="Обустройство">Обустройство</option>
                                <option value="Ремонт">Ремонт</option>
                            </select>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div id="map" style="width: 100%; height: 500px;"></div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row mt-4">
        <div class="col-12 text-center">
            <p>Посетите наш <a href="https://burlida.by/" target="_blank" class="btn btn-outline-primary">официальный сайт</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://api-maps.yandex.ru/2.1/?apikey=4241305e-2e84-4c08-92f5-27f017cf2057&lang=ru_RU" type="text/javascript"></script>
    <script>
        const ordersForMap = @Html.Raw(ordersForMapJson);
        let ymapsMap;
        let allPlacemarks = [];

        function initMapYandex() {
            ymapsMap = new ymaps.Map("map", {
                center: [53.9, 27.55],
                zoom: 9
            });

            const statusPresets = {
                "Ожидание": "islands#orangeCircleIcon",
                "Ремонт": "islands#redCircleIcon",
                "Бурение": "islands#greenCircleIcon",
                "Обустройство": "islands#blueCircleIcon"
            };

            const points = [];

            ordersForMap.forEach(o => {
                if (!o.coordinates) return;
                const parts = o.coordinates.split(/[,\s]+/).map(x => parseFloat(x.replace(",", ".")));
                if (parts.length < 2 || isNaN(parts[0]) || isNaN(parts[1])) return;

                const coords = [parts[0], parts[1]];
                const preset = statusPresets[o.status] || "islands#grayCircleIcon";

                const placemark = new ymaps.Placemark(
                    coords,
                    {
                        balloonContent: `<strong>${o.address ?? ""}</strong><br/>Статус: ${o.status ?? ""}`
                    },
                    {
                        preset: preset
                    }
                );

                placemark.orderStatus = o.status != null ? String(o.status).trim() : "";

                ymapsMap.geoObjects.add(placemark);
                allPlacemarks.push(placemark);
                points.push(coords);
            });

            if (points.length > 0) {
                const bounds = ymaps.util.bounds.fromPoints(points);
                ymapsMap.setBounds(bounds, { checkZoomRange: true, zoomMargin: 20 });
            }

            const statusFilter = document.getElementById("statusFilter");
            if (statusFilter) {
                statusFilter.addEventListener("change", () => {
                    const value = (statusFilter.value || "").trim();
                    allPlacemarks.forEach(p => {
                        ymapsMap.geoObjects.remove(p);
                        const st = (p.orderStatus || "").trim();
                        if (!value || st === value) {
                            ymapsMap.geoObjects.add(p);
                        }
                    });
                });
            }
        }

        if (window.ymaps) {
            ymaps.ready(initMapYandex);
        }
    </script>
}
