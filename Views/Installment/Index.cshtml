@model DP_BurLida.Models.InstallmentListViewModel

@{
    ViewData["Title"] = "Рассрочки";
}

<div class="content-card">
    <style>
        .installments-table tbody tr:hover td {
            background-color: #f9fafb;
        }
    </style>

    <h1>Рассрочки</h1>
    <p class="text-muted">Отображаются заявки, в которых включена рассрочка по бурению или обустройству.</p>

    <div class="table-responsive">
        <table class="table align-middle installments-table">
            <thead>
                <tr>
                    <th>Адрес</th>
                    <th>Телефон</th>
                    <th>Клиент</th>
                    <th class="text-end">Остаток рассрочки</th>
                    <th class="text-end">Текущий платеж</th>
                    <th>Срок оплаты</th>
                    <th>Номер Е-РИП</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Any())
                {
                    foreach (var item in Model.Items)
                    {
                        <tr class="installment-row" data-order-id="@item.OrderId">
                            <td>@item.Address</td>
                            <td>@item.Phone</td>
                            <td>@item.ClientName</td>
                            <td class="text-end fw-semibold">@item.TotalRemainingAmount</td>
                            <td class="text-end">@item.CurrentPaymentAmount</td>
                            <td>
                                @(item.CurrentPaymentDueDate?.ToString("dd.MM.yyyy") ?? "Не назначена")
                            </td>
                            <td>@(string.IsNullOrEmpty(item.InstallmentEripNumber) ? "Не указан" : item.InstallmentEripNumber)</td>
                            <td class="text-nowrap installment-actions">
                                <a asp-controller="Order" asp-action="Edit" asp-route-id="@item.OrderId"
                                   class="btn btn-sm btn-outline-warning me-1" title="Редактировать">
                                    <i class="fas fa-pen"></i>
                                </a>
                                <a asp-controller="Order" asp-action="Details" asp-route-id="@item.OrderId"
                                   class="btn btn-sm btn-outline-info me-1" title="Подробности">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-controller="Order" asp-action="Delete" asp-route-id="@item.OrderId"
                                   class="btn btn-sm btn-outline-danger" title="Удалить">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-3">
                            Рассрочек пока нет.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.installment-row').forEach(function (row) {
                row.addEventListener('click', function (e) {
                    if (e.target.closest('.installment-actions')) {
                        return;
                    }
                    var id = this.getAttribute('data-order-id');
                    if (!id) return;
                    window.location.href = '@Url.Action("Details", "Order")' + '/' + id;
                });
            });
        });
    </script>
}

