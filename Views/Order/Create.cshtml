@model DP_BurLida.Data.ModelsData.OrderModelData

@{
    ViewData["Title"] = "Создание заказа";
}

<h1>Создание заказа</h1>
<hr />
<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="row">
        <!-- ЛЕВАЯ КОЛОНКА -->
        <div class="col-md-6">
            <!-- 1. Адрес -->
            <div class="form-group">
                <label asp-for="Address" class="control-label">Адрес</label>
                <input asp-for="Address" class="form-control" />
                <span class="form-text text-muted">Полный адрес объекта (улица, дом, населённый пункт).</span>
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <!-- 2. Диаметр -->
            <div class="form-group">
                <label asp-for="Diameter" class="control-label">Диаметр</label>
                <select asp-for="Diameter" class="form-control">
                    <option value="">-- выберите диаметр --</option>
                    <option value="32">32</option>
                    <option value="90">90</option>
                    <option value="125">125</option>
                </select>
                <span asp-validation-for="Diameter" class="text-danger"></span>
            </div>

            <!-- 3. Цена за метр -->
            <div class="form-group">
                <label asp-for="PricePerMeter" class="control-label">Цена за метр</label>
                <select asp-for="PricePerMeter" class="form-control">
                    <option value="">-- выберите цену за метр --</option>
                    <option value="70">70</option>
                    <option value="75">75</option>
                    <option value="80">80</option>
                    <option value="85">85</option>
                    <option value="90">85-90</option>
                    <option value="95">90-95</option>
                    <option value="100">95-100</option>
                    <option value="105">100-105</option>
                    <option value="120">120</option>
                    <option value="140">140</option>
                </select>
                <span asp-validation-for="PricePerMeter" class="text-danger"></span>
            </div>

            <!-- 4. Насос -->
            <div class="form-group">
                <label asp-for="Pump" class="control-label">Насос</label>
                <select asp-for="Pump" class="form-control">
                    <option value="0">не нужен</option>
                    <option value="600">монтаж насоса заказчика от 600 руб</option>
                    <option value="1100">насос от 1100 руб</option>
                    <option value="1101">насос от 1100 - взять 4куб насос</option>
                </select>
                <span asp-validation-for="Pump" class="text-danger"></span>
            </div>

            <!-- 5. Обустройство -->
            <div class="form-group">
                <label asp-for="Arrangement" class="control-label">Обустройство</label>
                <select asp-for="Arrangement" class="form-control">
                    <option value="Не нужно">не нужно</option>
                    <option value="Врезать адаптер от 1000 руб">врезать адаптер от 1000руб</option>
                    <option value="Врезка через адаптер от 1300 руб">врезка через адаптер от 1300руб</option>
                    <option value="Адаптер от 2000 руб">адаптер от 2000руб</option>
                    <option value="Кессон ж/б от 3500 руб">Кессон ж/б от 3500 руб</option>
                    <option value="Пластиковый кессон от 6500 руб">платиковый кессон от 6500 руб</option>
                </select>
                <span class="form-text text-muted">Необязательное поле.</span>
                <span asp-validation-for="Arrangement" class="text-danger"></span>
            </div>

            <!-- 6. Канализация -->
            <div class="form-group">
                <label asp-for="Sewer" class="control-label">Канализация</label>
                <input asp-for="Sewer" class="form-control" />
                <span class="form-text text-muted">Необязательное поле.</span>
                <span asp-validation-for="Sewer" class="text-danger"></span>
            </div>

            <!-- 7. Информация -->
            <div class="form-group">
                <label asp-for="Info" class="control-label">Информация</label>
                <input asp-for="Info" class="form-control" />
                <span asp-validation-for="Info" class="text-danger"></span>
            </div>

            <!-- 8. Номер телефона -->
            <div class="form-group">
                <label asp-for="Phone" class="control-label">Телефон</label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <!-- 9. Имя клиента -->
            <div class="form-group">
                <label asp-for="NameClient" class="control-label">Имя клиента</label>
                <input asp-for="NameClient" class="form-control" />
                <span asp-validation-for="NameClient" class="text-danger"></span>
            </div>

            <!-- 10. Координаты -->
            <div class="form-group">
                <label asp-for="Coordinates" class="control-label">Координаты</label>
                <input asp-for="Coordinates" class="form-control" placeholder="Широта, долгота (например, 53.9, 27.55)" />
                <span class="form-text text-muted">Будет использоваться для отображения точки на карте.</span>
                <span asp-validation-for="Coordinates" class="text-danger"></span>
            </div>
        </div>

        <!-- ПРАВАЯ КОЛОНКА -->
        <div class="col-md-6">
            <!-- 11. Статус -->
            <div class="form-group">
                <label asp-for="Status" class="control-label">Статус</label>
                <select asp-for="Status" class="form-control">
                    <option value="">Выберите статус</option>
                    <option value="Ожидание">Ожидание</option>
                    <option value="Бурение">Бурение</option>
                    <option value="Обустройство">Обустройство</option>
                    <option value="Ремонт">Ремонт</option>
                    <option value="Отдали подрядчикам">Отдали подрядчикам</option>
                    <option value="Завершен">Завершен</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <!-- 11.1. Чья бригада -->
            <div class="form-group">
                <label asp-for="BrigadeStatus" class="control-label">Чья бригада</label>
                <select asp-for="BrigadeStatus" class="form-control">
                    <option value="">-- не выбрано --</option>
                    <option value="приоритет нашей бригаде">приоритет нашей бригаде</option>
                    <option value="Наша бригада">Наша бригада</option>
                    <option value="Возможно подрядчики">Возможно подрядчики</option>
                    <option value="подрядчик">подрядчик</option>
                </select>
                <span class="form-text text-muted">Используется для визуального выделения заявок в списке и календаре.</span>
                <span asp-validation-for="BrigadeStatus" class="text-danger"></span>
            </div>

            <!-- 12. Дата бурения -->
            <div class="form-group">
                <label asp-for="WorkDate" class="control-label">Дата бурения</label>
                <input asp-for="WorkDate" type="date" class="form-control" />
                <span asp-validation-for="WorkDate" class="text-danger"></span>
            </div>

            <!-- 13. Бригада бурения -->
            <div class="form-group">
                <label asp-for="DrillingBrigadeId" class="control-label">Бригада бурения</label>
                <select asp-for="DrillingBrigadeId" class="form-control" asp-items="ViewBag.DrillingBrigades">
                    <option value="">-- выберите бригаду бурения --</option>
                </select>
                <span asp-validation-for="DrillingBrigadeId" class="text-danger"></span>
            </div>

            <!-- 14. Количество метров -->
            <div class="form-group">
                <label asp-for="MetersCount" class="control-label">Количество метров</label>
                <input asp-for="MetersCount" type="number" class="form-control" />
                <span class="form-text text-muted">Необязательное поле.</span>
                <span asp-validation-for="MetersCount" class="text-danger"></span>
            </div>

            <!-- 15. Глубина -->
            <div class="form-group">
                <label asp-for="Depth" class="control-label">Глубина</label>
                <input asp-for="Depth" class="form-control" />
                <span class="form-text text-muted">Необязательное поле.</span>
                <span asp-validation-for="Depth" class="text-danger"></span>
            </div>

            <!-- 16. Динамика -->
            <div class="form-group">
                <label asp-for="DynamicLevel" class="control-label">Динамика</label>
                <input asp-for="DynamicLevel" class="form-control" />
                <span class="form-text text-muted">Необязательное поле.</span>
                <span asp-validation-for="DynamicLevel" class="text-danger"></span>
            </div>

            <!-- 17. Статика -->
            <div class="form-group">
                <label asp-for="StaticLevel" class="control-label">Статика</label>
                <input asp-for="StaticLevel" class="form-control" />
                <span class="form-text text-muted">Необязательное поле.</span>
                <span asp-validation-for="StaticLevel" class="text-danger"></span>
            </div>

            <!-- 18. Фильтр -->
            <div class="form-group">
                <label asp-for="Filter" class="control-label">Фильтр</label>
                <input asp-for="Filter" class="form-control" />
                <span class="form-text text-muted">Необязательное поле.</span>
                <span asp-validation-for="Filter" class="text-danger"></span>
            </div>

            <!-- 19. Насос смонтирован -->
            <div class="form-group">
                <label asp-for="PumpInstalled" class="control-label">Насос смонтирован</label>
                <input asp-for="PumpInstalled" class="form-control" />
                <span class="form-text text-muted">Необязательное поле.</span>
                <span asp-validation-for="PumpInstalled" class="text-danger"></span>
            </div>

            <!-- 19.1. Итого за бурение скважины -->
            <div class="form-group">
                <label asp-for="TotalDrillingAmount" class="control-label">Итого за бурение скважины</label>
                <input asp-for="TotalDrillingAmount" class="form-control" />
                <span class="form-text text-muted">Необязательное текстовое поле.</span>
                <span asp-validation-for="TotalDrillingAmount" class="text-danger"></span>
            </div>

            <!-- 20. Дата обустройства -->
            <div class="form-group">
                <label asp-for="ArrangementDate" class="control-label">Дата обустройства</label>
                <input asp-for="ArrangementDate" type="date" class="form-control" />
                <span class="form-text text-muted">Необязательное поле.</span>
                <span asp-validation-for="ArrangementDate" class="text-danger"></span>
            </div>

            <!-- 21. Бригада обустройства -->
            <div class="form-group">
                <label asp-for="ArrangementBrigadeId" class="control-label">Бригада обустройства</label>
                <select asp-for="ArrangementBrigadeId" class="form-control" asp-items="ViewBag.ArrangementBrigades">
                    <option value="">-- выберите бригаду обустройства --</option>
                </select>
                <span asp-validation-for="ArrangementBrigadeId" class="text-danger"></span>
            </div>

            <!-- 22. Обустройство выполнено -->
            <div class="form-group">
                <label asp-for="ArrangementDone" class="control-label">Обустройство выполнено</label>
                <input asp-for="ArrangementDone" class="form-control" />
                <span class="form-text text-muted">Необязательное поле.</span>
                <span asp-validation-for="ArrangementDone" class="text-danger"></span>
            </div>
            <!-- 22.1. Итого за обустройство -->
            <div class="form-group">
                <label asp-for="TotalArrangementAmount" class="control-label">Итого за обустройство</label>
                <input asp-for="TotalArrangementAmount" class="form-control" />
                <span class="form-text text-muted">Необязательное текстовое поле.</span>
                <span asp-validation-for="TotalArrangementAmount" class="text-danger"></span>
            </div>

            <!-- 23. Отдать подрядчикам -->
            <div class="form-group">
                <label asp-for="Contractor" class="control-label">Отдать подрядчикам</label>
                <select asp-for="Contractor" class="form-control">
                    <option value="">-- не выбрано --</option>
                    <option value="Саша">Саша</option>
                    <option value="Олег">Олег</option>
                    <option value="Александр">Александр</option>
                </select>
                <span class="form-text text-muted">Необязательное поле.</span>
                <span asp-validation-for="Contractor" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="form-group mt-3">
        <input type="submit" value="Создать" class="btn btn-success" />
        <a asp-action="Index" class="btn btn-secondary">Отмена</a>
    </div>
</form>

<div>
    <a asp-action="Index">Вернуться к списку</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
