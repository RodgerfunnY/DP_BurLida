@model IEnumerable<DP_BurLida.Data.ModelsData.OrderModelData>

@{
    ViewData["Title"] = "Заказы";
}

<div class="content-card">
<style>
    .order-row {
        cursor: pointer;
    }

    .orders-table {
        border-collapse: separate;
        border-spacing: 0 0.5rem;
    }

    .orders-table thead tr th {
        border-bottom: 1px solid #e2e8f0;
    }

    .orders-table tbody tr.order-row td {
        background-color: #ffffff;
        border-top: 1px solid #d0d7e2;
        border-bottom: 1px solid #d0d7e2;
    }

    .orders-table tbody tr.order-row td:first-child {
        border-left: 1px solid #d0d7e2;
        border-top-left-radius: 0.75rem;
        border-bottom-left-radius: 0.75rem;
    }

    .orders-table tbody tr.order-row td:last-child {
        border-right: 1px solid #d0d7e2;
        border-top-right-radius: 0.75rem;
        border-bottom-right-radius: 0.75rem;
    }

    .orders-table tbody tr.order-row:hover td {
        background-color: #f9fafb;
    }

    .order-details-row > td {
        border-top: none;
        padding-top: 0;
    }

    .order-details-card {
        border-radius: 1rem;
        border: 1.5px solid #d0d7e2;
        background-color: #ffffff;
        box-shadow: 0 0.25rem 0.75rem rgba(15, 23, 42, 0.06);
    }

    .order-brigade-priority .order-details-card,
    tr.order-brigade-priority td {
        background-color: #ffe5e5 !important;
    }

    .order-brigade-ours .order-details-card,
    tr.order-brigade-ours td {
        background-color: #e6ffea !important;
    }

    .order-brigade-maybe-contractors .order-details-card,
    tr.order-brigade-maybe-contractors td {
        background-color: #fff8e1 !important;
    }

    .order-manager-comment {
        max-width: 12rem;
        vertical-align: middle;
    }

    .order-manager-comment-text {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        word-break: break-word;
        font-size: 0.9rem;
        line-height: 1.35;
    }

    @@media (max-width: 576px) {
        .orders-table {
            font-size: 0.85rem;
        }

        .order-manager-comment {
            max-width: 8rem;
        }

        .order-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.25rem;
        }

        .order-actions .btn {
            padding: 0.15rem 0.4rem;
            font-size: 0.7rem;
        }
    }
</style>
<h1>Заказы</h1>

<div class="row mb-3">
    <div class="col-md-6">
        <a asp-action="Create" class="btn btn-success">Создать новый заказ</a>
        <a asp-controller="Archive" asp-action="Index" class="btn btn-secondary">Архив завершенных</a>
    </div>
    <div class="col-md-6">
        <form asp-action="Index" method="get" class="d-flex">
            <div class="input-group">
                <input type="text" name="searchTerm" class="form-control" 
                       placeholder="Поиск по адресу, насосу, обустройству, телефону, имени..." 
                       value="@ViewBag.SearchTerm"
                       title="Поиск по адресу, насосу, обустройству, телефону, имени, координатам и др." />
                <button type="submit" class="btn btn-outline-secondary">
                    <i class="fas fa-search"></i> Поиск
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
                {
                    <a asp-action="Index" class="btn btn-outline-danger">
                        <i class="fas fa-times"></i> Очистить
                    </a>
                }
            </div>
        </form>
    </div>
</div>

@if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i>
        Результаты поиска по запросу: "<strong>@ViewBag.SearchTerm</strong>"
        @if (Model != null && Model.Any())
        {
            <span class="badge bg-primary ms-2">Найдено: @Model.Count()</span>
        }
        else
        {
            <span class="badge bg-warning ms-2">Ничего не найдено</span>
        }
    </div>
}
<div class="table-responsive">
<table class="table align-middle orders-table">
    <thead>
        <tr>
            <th>Адрес</th>
            <th>Скважина (диаметр)</th>
            <th>Насос</th>
            <th>Обустройство</th>
            <th title="Текст из поля «Информация» при создании заявки">Комментарий</th>
            <th>Телефон</th>
            <th>Имя клиента</th>
            <th>Создал</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var pumpText = item.Pump switch
            {
                0 => "не нужен",
                600 => "монтаж насоса заказчика от 600 руб",
                1100 => "насос от 1100 руб",
                1101 => "насос от 1100 - взять 4куб насос",
                _ => item.Pump.ToString()
            };
            var brigadeClass = item.BrigadeStatus switch
            {
                "приоритет нашей бригаде" => "order-brigade-priority",
                "Наша бригада" => "order-brigade-ours",
                "Возможно подрядчики" => "order-brigade-maybe-contractors",
                _ => string.Empty
            };

            <tr class="order-row @brigadeClass" data-order-id="@item.Id">
                <td>@item.City</td>
                <td>@item.Diameter</td>
                <td>@pumpText</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.Arrangement))
                    {
                        @item.Arrangement
                    }
                    else
                    {
                        <span class="text-muted">Не указано</span>
                    }
                </td>
                <td class="order-manager-comment">
                    @if (!string.IsNullOrWhiteSpace(item.Info))
                    {
                        <span class="order-manager-comment-text" title="@item.Info">@item.Info</span>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>
                <td>@item.Phone</td>
                <td>@item.NameClient</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.CreatedBy))
                    {
                        @item.CreatedBy
                    }
                    else
                    {
                        <span class="text-muted">Не указано</span>
                    }
                </td>
                <td class="text-nowrap order-actions">
                    <a asp-action="Edit" asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-warning me-1"
                       title="Редактировать">
                        <i class="fas fa-pen"></i>
                    </a>
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary me-1 order-toggle-comments"
                            data-order-id="@item.Id"
                            title="Комментарии">
                        <i class="fas fa-comments"></i>
                    </button>
                    <button type="button"
                            class="btn btn-sm btn-outline-info me-1 order-toggle-details"
                            data-target="#order-details-@item.Id"
                            title="Показать подробности">
                        <i class="fas fa-eye"></i>
                    </button>
                    <a asp-action="Delete" asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-danger"
                       title="Удалить">
                        <i class="fas fa-trash"></i>
                    </a>
                </td>
            </tr>
            <tr class="order-details-row collapse @brigadeClass" id="order-details-@item.Id">
                <td colspan="9">
                    <div class="card order-details-card mb-2">
                        <div class="card-body">
                            <ul class="nav nav-tabs mb-2" id="order-tabs-@item.Id" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" id="order-main-tab-@item.Id" data-bs-toggle="tab" data-bs-target="#order-main-@item.Id" type="button" role="tab" aria-controls="order-main-@item.Id" aria-selected="true">Основная информация</button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="order-drilling-tab-@item.Id" data-bs-toggle="tab" data-bs-target="#order-drilling-@item.Id" type="button" role="tab" aria-controls="order-drilling-@item.Id" aria-selected="false">Бурение</button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="order-arrangement-tab-@item.Id" data-bs-toggle="tab" data-bs-target="#order-arrangement-@item.Id" type="button" role="tab" aria-controls="order-arrangement-@item.Id" aria-selected="false">Обустройство</button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="order-installment-tab-@item.Id" data-bs-toggle="tab" data-bs-target="#order-installment-@item.Id" type="button" role="tab" aria-controls="order-installment-@item.Id" aria-selected="false">Рассрочка</button>
                                </li>
                            </ul>
                            <div class="tab-content" id="order-tabs-content-@item.Id">
                                <div class="tab-pane fade show active" id="order-main-@item.Id" role="tabpanel" aria-labelledby="order-main-tab-@item.Id">
                                    <p class="mb-1"><strong>Адрес:</strong> @item.City</p>
                                    <p class="mb-1"><strong>Диаметр:</strong> @item.Diameter мм</p>
                                    <p class="mb-1"><strong>Цена за метр:</strong> @item.PricePerMeter руб.</p>
                                    <p class="mb-1"><strong>Насос:</strong> @pumpText</p>
                                    <p class="mb-1"><strong>Обустройство:</strong> @(!string.IsNullOrEmpty(item.Arrangement) ? item.Arrangement : "Не указано")</p>
                                    <p class="mb-1"><strong>Канализация:</strong> @(string.IsNullOrEmpty(item.Sewer) ? "Не указано" : item.Sewer)</p>
                                    <p class="mb-1"><strong>Комментарий:</strong> @item.Info</p>
                                    <p class="mb-1"><strong>Телефон:</strong> @item.Phone</p>
                                    <p class="mb-1"><strong>Имя клиента:</strong> @item.NameClient</p>
                                    <p class="mb-1"><strong>Координаты:</strong> @(string.IsNullOrEmpty(item.Coordinates) ? "Не указаны" : item.Coordinates)</p>
                                </div>
                                <div class="tab-pane fade" id="order-drilling-@item.Id" role="tabpanel" aria-labelledby="order-drilling-tab-@item.Id">
                                    <p class="mb-1">
                                        <strong>Статус:</strong>
                                        @if (!string.IsNullOrEmpty(item.Status))
                                        {
                                            <span class="badge @(item.Status switch {
                                                "Ожидание" => "bg-warning",
                                                "Бурение" => "bg-primary",
                                                "Обустройство" => "bg-info",
                                                "Ремонт" => "bg-danger",
                                                "Завершен" => "bg-success",
                                                "Отдали подрядчикам" => "bg-dark",
                                                _ => "bg-secondary"
                                            })">@item.Status</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Не указан</span>
                                        }
                                    </p>
                                    <p class="mb-1"><strong>Чья бригада:</strong> @(string.IsNullOrEmpty(item.BrigadeStatus) ? "Не указано" : item.BrigadeStatus)</p>
                                    <p class="mb-1"><strong>Дата бурения:</strong> @(item.WorkDate?.ToString("dd.MM.yyyy") ?? "Не назначена")</p>
                                    <p class="mb-1">
                                        <strong>Бригада бурения:</strong>
                                        @if (item.DrillingBrigade != null)
                                        {
                                            @($"{item.DrillingBrigade.NameBrigade} (Ответственный: {item.DrillingBrigade.ResponsibleUser?.FullName ?? "Не назначен"})")
                                        }
                                        else
                                        {
                                            @:Не назначена
                                        }
                                    </p>
                                    <p class="mb-1"><strong>Количество метров:</strong> @(item.MetersCount.HasValue ? item.MetersCount.ToString() : "Не указано")</p>
                                    <p class="mb-1"><strong>Глубина:</strong> @(string.IsNullOrEmpty(item.Depth) ? "Не указано" : item.Depth)</p>
                                    <p class="mb-1"><strong>Динамика:</strong> @(string.IsNullOrEmpty(item.DynamicLevel) ? "Не указано" : item.DynamicLevel)</p>
                                    <p class="mb-1"><strong>Статика:</strong> @(string.IsNullOrEmpty(item.StaticLevel) ? "Не указано" : item.StaticLevel)</p>
                                    <p class="mb-1"><strong>Фильтр:</strong> @(string.IsNullOrEmpty(item.Filter) ? "Не указано" : item.Filter)</p>
                                    <p class="mb-1"><strong>Насос смонтирован:</strong> @(string.IsNullOrEmpty(item.PumpInstalled) ? "Не указано" : item.PumpInstalled)</p>
                                </div>
                                <div class="tab-pane fade" id="order-arrangement-@item.Id" role="tabpanel" aria-labelledby="order-arrangement-tab-@item.Id">
                                    <p class="mb-1"><strong>Дата обустройства:</strong> @(item.ArrangementDate?.ToString("dd.MM.yyyy") ?? "Не назначена")</p>
                                    <p class="mb-1">
                                        <strong>Бригада обустройства:</strong>
                                        @if (item.ArrangementBrigade != null)
                                        {
                                            @($"{item.ArrangementBrigade.NameBrigade} (Ответственный: {item.ArrangementBrigade.ResponsibleUser?.FullName ?? "Не назначен"})")
                                        }
                                        else
                                        {
                                            @:Не назначена
                                        }
                                    </p>
                                    <p class="mb-1"><strong>Обустройство выполнено:</strong> @(string.IsNullOrEmpty(item.ArrangementDone) ? "Не указано" : item.ArrangementDone)</p>
                                </div>
                                <div class="tab-pane fade" id="order-installment-@item.Id" role="tabpanel" aria-labelledby="order-installment-tab-@item.Id">
                                    <p class="mb-1"><strong>Итого за бурение скважины:</strong> @(string.IsNullOrEmpty(item.TotalDrillingAmount) ? "Не указано" : item.TotalDrillingAmount)</p>
                                    <p class="mb-1"><strong>Итого за обустройство:</strong> @(string.IsNullOrEmpty(item.TotalArrangementAmount) ? "Не указано" : item.TotalArrangementAmount)</p>
                                    <p class="mb-1"><strong>Номер Е-РИП:</strong> @(string.IsNullOrEmpty(item.InstallmentEripNumber) ? "Не указан" : item.InstallmentEripNumber)</p>
                                    @* Здесь при необходимости можно позже вывести детальный график платежей *@
                                    <p class="mb-0"><strong>Отдать подрядчикам:</strong> @(string.IsNullOrEmpty(item.Contractor) ? "Не выбрано" : item.Contractor)</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </td>
            </tr>

            <tr class="order-comments-row collapse @brigadeClass" id="order-comments-@item.Id">
                <td colspan="9">
                    <div class="card order-details-card mb-2">
                        <div class="card-body">
                            <div id="order-comments-content-@item.Id" data-loaded="0" class="small">
                                <div class="text-muted">Загрузка...</div>
                            </div>
                        </div>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <h4>Нет активных заказов</h4>
        <p>Все заказы завершены или еще не созданы.</p>
        <a asp-action="Create" class="btn btn-success">Создать первый заказ</a>
    </div>
}
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Клик по иконке глаза
            document.querySelectorAll('.order-toggle-details').forEach(function (btn) {
                btn.addEventListener('click', function (e) {
                    // Не даём событию всплыть до строки, чтобы не было двойного переключения
                    e.stopPropagation();
                    var targetSelector = this.getAttribute('data-target');
                    var row = document.querySelector(targetSelector);
                    if (!row) return;

                    row.classList.toggle('show');
                });
            });

            function loadComments(orderId) {
                var content = document.getElementById('order-comments-content-' + orderId);
                if (!content) return;
                if (content.dataset.loaded === '1') return;

                content.innerHTML = '<div class="text-muted">Загрузка...</div>';
                var hash = '#order-' + orderId + '-comments';
                var returnUrl = window.location.pathname + window.location.search + hash;

                fetch('@Url.Action("ListPartial", "OrderComment")' + '?orderId=' + orderId + '&returnUrl=' + encodeURIComponent(returnUrl), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                    .then(function (r) { return r.ok ? r.text() : Promise.reject(); })
                    .then(function (html) {
                        content.innerHTML = html;
                        content.dataset.loaded = '1';
                        var input = content.querySelector('input[name="text"]');
                        if (input) input.focus();
                    })
                    .catch(function () {
                        content.innerHTML = '<div class="text-danger">Не удалось загрузить комментарии.</div>';
                    });
            }

            function toggleComments(orderId, forceShow) {
                var row = document.getElementById('order-comments-' + orderId);
                if (!row) return;

                var willShow = (typeof forceShow === 'boolean') ? forceShow : !row.classList.contains('show');
                if (willShow) {
                    row.classList.add('show');
                    window.location.hash = 'order-' + orderId + '-comments';
                    loadComments(orderId);
                } else {
                    row.classList.remove('show');
                }
            }

            // Клик по иконке комментариев
            document.querySelectorAll('.order-toggle-comments').forEach(function (btn) {
                btn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    var orderId = this.getAttribute('data-order-id');
                    if (!orderId) return;
                    toggleComments(orderId);
                });
            });

            // Клик по любой части строки заказа (кроме ячейки с действиями)
            document.querySelectorAll('.order-row').forEach(function (row) {
                row.addEventListener('click', function (e) {
                    if (e.target.closest('.order-actions')) {
                        return;
                    }

                    var orderId = this.getAttribute('data-order-id');
                    if (!orderId) return;

                    var detailsRow = document.querySelector('#order-details-' + orderId);
                    if (!detailsRow) return;

                    detailsRow.classList.toggle('show');
                });
            });

            // Если перезагрузили страницу после добавления комментария — открыть нужный блок
            if (window.location.hash) {
                var m = window.location.hash.match(/^#order-(\d+)-comments$/);
                if (m) {
                    toggleComments(m[1], true);
                }
            }
        });
    </script>
}
