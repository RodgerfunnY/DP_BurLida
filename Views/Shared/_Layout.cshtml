<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DP_BurLida</title>
    <script type="importmap"></script>
    <environment include="Development">
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    </environment>
    <environment exclude="Development">
        <link rel="preconnect" href="https://cdn.jsdelivr.net" />
        <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" referrerpolicy="no-referrer" />
    </environment>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DP_BurLida.styles.css" asp-append-version="true" />
    <environment include="Development">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" referrerpolicy="no-referrer" />
    </environment>
    <environment exclude="Development">
        <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" referrerpolicy="no-referrer" />
    </environment>
    <style>
        /* Общий макет: левый сайдбар + основное содержимое */
        body {
            background: #f4f6fb;
        }

        .app-shell {
            min-height: 100vh;
            display: flex;
            flex-direction: row;
            min-width: 0;
            max-width: 100%;
            width: 100%;
        }

        .app-sidebar {
            width: 230px;
            background: linear-gradient(180deg, #0b3c7d 0%, #021633 100%);
            color: #ffffff;
            display: flex;
            flex-direction: column;
            padding: 1rem 0.75rem;
        }

        .app-sidebar-brand {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
            padding: 0 0.25rem;
        }

        .app-sidebar-brand-icon {
            font-size: 1.4rem;
        }

        .app-sidebar-brand-text {
            font-size: 0.95rem;
            font-weight: 600;
            letter-spacing: 0.04em;
        }

        .app-sidebar-nav {
            list-style: none;
            margin: 0;
            padding: 0;
            flex: 1;
        }

        .app-sidebar-nav .nav-link {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            color: #c3d4f5;
            padding: 0.45rem 0.6rem;
            border-radius: 0.5rem;
            font-size: 0.9rem;
            margin-bottom: 0.15rem;
            text-decoration: none;
            transition: background 0.15s ease, color 0.15s ease, transform 0.05s ease;
        }

        .app-sidebar-nav .nav-link i {
            width: 1.2rem;
            text-align: center;
        }

        .app-sidebar-nav .nav-link:hover {
            background: rgba(255, 255, 255, 0.08);
            color: #ffffff;
            transform: translateX(1px);
        }

        .app-sidebar-nav .nav-link.active {
            background: #ffffff;
            color: #0b3c7d;
            font-weight: 600;
        }

        .app-sidebar-footer {
            margin-top: 1.5rem;
            font-size: 0.85rem;
            color: #8ea5d8;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.35rem;
        }

        .app-sidebar-user {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.25rem;
        }

        .app-sidebar-user-name {
            font-size: 0.95rem;
            font-weight: 600;
            color: #ffffff;
        }

        .app-sidebar-user button.logout-btn {
            border-radius: 999px;
            border-width: 1px;
        }

        .app-main {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .app-main-header {
            padding: 0.75rem 1.5rem;
            border-bottom: 1px solid rgba(15, 23, 42, 0.06);
            background: #ffffff;
            display: flex;
            justify-content: flex-end;
            align-items: center;
        }

        .app-main-content {
            padding: 1.5rem;
        }

        .app-mobile-topbar {
            flex-shrink: 0;
            background: linear-gradient(90deg, #0b3c7d 0%, #021633 100%);
            color: #fff;
            padding: 0.5rem 0.75rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            box-shadow: 0 2px 8px rgba(2, 22, 51, 0.35);
        }

        .app-mobile-topbar .menu-toggle {
            color: #fff;
            padding: 0.35rem 0.5rem;
            border: none;
            background: rgba(255, 255, 255, 0.12);
            border-radius: 0.5rem;
            line-height: 1;
        }

        .app-mobile-topbar .menu-toggle:hover {
            background: rgba(255, 255, 255, 0.2);
            color: #fff;
        }

        .app-offcanvas-sidebar {
            background: linear-gradient(180deg, #0b3c7d 0%, #021633 100%);
            color: #fff;
            width: min(300px, 88vw) !important;
        }

        .app-offcanvas-sidebar .offcanvas-header {
            border-bottom: 1px solid rgba(255, 255, 255, 0.12);
        }

        .app-offcanvas-sidebar .offcanvas-body {
            display: flex;
            flex-direction: column;
            padding: 0.75rem 0.75rem 1rem;
            overflow-y: auto;
        }

        .app-offcanvas-sidebar .app-sidebar-nav {
            flex: 1;
        }

        @@media (max-width: 991.98px) {
            .app-main-header {
                display: none;
            }

            .app-main-content {
                padding: 1rem 0.75rem 1.25rem;
            }
        }

        @@media (max-width: 576px) {
            .app-main-content {
                padding: 0.75rem 0.65rem 1rem;
            }
        }
    </style>
</head>

<body>
    <div class="app-shell">
        <aside class="app-sidebar d-none d-lg-flex flex-column">
            @await Html.PartialAsync("_AppSidebarInner")
        </aside>

        <div class="offcanvas offcanvas-start app-offcanvas-sidebar d-lg-none" tabindex="-1" id="appSidebarOffcanvas" aria-labelledby="appSidebarOffcanvasLabel">
            <div class="offcanvas-header">
                <h5 class="offcanvas-title text-white" id="appSidebarOffcanvasLabel">Меню</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Закрыть"></button>
            </div>
            <div class="offcanvas-body">
                @await Html.PartialAsync("_AppSidebarInner")
            </div>
        </div>

        <div class="app-main">
            <div class="app-mobile-topbar d-lg-none">
                <button class="menu-toggle" type="button" data-bs-toggle="offcanvas" data-bs-target="#appSidebarOffcanvas" aria-controls="appSidebarOffcanvas" aria-label="Открыть меню">
                    <i class="fa-solid fa-bars fa-lg"></i>
                </button>
                <span class="fw-semibold small">DP_BurLida</span>
            </div>
            <header class="app-main-header">
            </header>
            <main role="main" class="app-main-content">
                @RenderBody()
            </main>
            <footer class="border-top footer text-muted bg-light mt-auto">
                <div class="container-fluid py-2 px-3">
                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2 text-center text-sm-start">
                        <span class="small">&copy; 2025 - DP_BurLida</span>
                        <a asp-area="" asp-controller="Home" asp-action="Privacy" class="btn btn-outline-secondary btn-sm">
                            Политика конфиденциальности
                        </a>
                    </div>
                </div>
            </footer>
        </div>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div id="notification-toast-container"
             class="toast-container position-fixed top-0 end-0 p-3"
             style="z-index: 1090;"
             data-notification-toast-url="@Url.Action("ToastUnread", "Notification")">
        </div>
    }
    <environment include="Development">
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js" crossorigin="anonymous"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" referrerpolicy="no-referrer"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js" referrerpolicy="no-referrer"></script>
    </environment>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
