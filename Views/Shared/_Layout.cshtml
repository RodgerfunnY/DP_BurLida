<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DP_BurLida</title>
    <script type="importmap"></script>
    <environment include="Development">
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    </environment>
    <environment exclude="Development">
        <link rel="preconnect" href="https://cdn.jsdelivr.net" />
        <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" referrerpolicy="no-referrer" />
    </environment>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DP_BurLida.styles.css" asp-append-version="true" />
    <environment include="Development">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" referrerpolicy="no-referrer" />
    </environment>
    <environment exclude="Development">
        <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" referrerpolicy="no-referrer" />
    </environment>
    <style>
        /* Общий макет: левый сайдбар + основное содержимое */
        body {
            background: #f4f6fb;
        }

        .app-shell {
            min-height: 100vh;
            display: flex;
            flex-direction: row;
        }

        .app-sidebar {
            width: 230px;
            background: linear-gradient(180deg, #0b3c7d 0%, #021633 100%);
            color: #ffffff;
            display: flex;
            flex-direction: column;
            padding: 1rem 0.75rem;
        }

        .app-sidebar-brand {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
            padding: 0 0.25rem;
        }

        .app-sidebar-brand-icon {
            font-size: 1.4rem;
        }

        .app-sidebar-brand-text {
            font-size: 0.95rem;
            font-weight: 600;
            letter-spacing: 0.04em;
        }

        .app-sidebar-nav {
            list-style: none;
            margin: 0;
            padding: 0;
            flex: 1;
        }

        .app-sidebar-nav .nav-link {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            color: #c3d4f5;
            padding: 0.45rem 0.6rem;
            border-radius: 0.5rem;
            font-size: 0.9rem;
            margin-bottom: 0.15rem;
            text-decoration: none;
            transition: background 0.15s ease, color 0.15s ease, transform 0.05s ease;
        }

        .app-sidebar-nav .nav-link i {
            width: 1.2rem;
            text-align: center;
        }

        .app-sidebar-nav .nav-link:hover {
            background: rgba(255, 255, 255, 0.08);
            color: #ffffff;
            transform: translateX(1px);
        }

        .app-sidebar-nav .nav-link.active {
            background: #ffffff;
            color: #0b3c7d;
            font-weight: 600;
        }

        .app-sidebar-footer {
            margin-top: 1.5rem;
            font-size: 0.85rem;
            color: #8ea5d8;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.35rem;
        }

        .app-sidebar-user {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.25rem;
        }

        .app-sidebar-user-name {
            font-size: 0.95rem;
            font-weight: 600;
            color: #ffffff;
        }

        .app-sidebar-user button.logout-btn {
            border-radius: 999px;
            border-width: 1px;
        }

        .app-main {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .app-main-header {
            padding: 0.75rem 1.5rem;
            border-bottom: 1px solid rgba(15, 23, 42, 0.06);
            background: #ffffff;
            display: flex;
            justify-content: flex-end;
            align-items: center;
        }

        .app-main-content {
            padding: 1.5rem;
        }

        @@media (max-width: 992px) {
            .app-shell {
                flex-direction: column;
            }

            .app-sidebar {
                width: 100%;
                flex-direction: row;
                overflow-x: auto;
                padding: 0.5rem 0.75rem;
            }

            .app-sidebar-brand {
                margin-bottom: 0;
                margin-right: 1rem;
            }

            .app-sidebar-nav {
                display: flex;
                flex-direction: row;
                gap: 0.25rem;
            }

            .app-sidebar-nav .nav-link {
                margin-bottom: 0;
                white-space: nowrap;
            }

            .app-main-header {
                padding-inline: 1rem;
            }

            .app-main-content {
                padding: 1rem;
            }
        }

        @@media (max-width: 576px) {
            .app-sidebar {
                padding-inline: 0.5rem;
            }

            .app-sidebar-brand-text {
                display: none;
            }

            .app-sidebar-nav .nav-link {
                padding: 0.35rem 0.45rem;
                font-size: 0.8rem;
                gap: 0.4rem;
            }

            .app-sidebar-nav .nav-link span {
                font-size: 0.8rem;
            }

            .app-main-content {
                padding: 0.75rem 0.75rem 1rem;
            }
        }
    </style>
</head>

<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    <div class="app-shell">
        <aside class="app-sidebar">
            <a class="app-sidebar-brand text-decoration-none text-white" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-screwdriver-wrench app-sidebar-brand-icon"></i>
                <span class="app-sidebar-brand-text">DP_BurLida</span>
            </a>
            <ul class="app-sidebar-nav">
                <li>
                    <a class="nav-link@(currentController=="Home" ? " active" : "")" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="fa-solid fa-house"></i>
                        <span>Главная</span>
                    </a>
                </li>
                <li>
                    <a class="nav-link@(currentController=="Order" ? " active" : "")" asp-area="" asp-controller="Order" asp-action="Index">
                        <i class="fa-solid fa-file-lines"></i>
                        <span>Заявки</span>
                    </a>
                </li>
                <li>
                    <a class="nav-link@(currentController=="Calendar" ? " active" : "")" asp-area="" asp-controller="Calendar" asp-action="Index">
                        <i class="fa-solid fa-calendar-days"></i>
                        <span>Календарь</span>
                    </a>
                </li>
                <li>
                    <a class="nav-link@(currentController=="Notification" ? " active" : "")" asp-area="" asp-controller="Notification" asp-action="Index">
                        <i class="fa-solid fa-bell"></i>
                        <span>Уведомления</span>
                    </a>
                </li>
                @if (User.IsInRole("Admin") || User.IsInRole("Director"))
                {
                    <li>
                        <a class="nav-link@(currentController=="User" ? " active" : "")" asp-area="" asp-controller="User" asp-action="Index">
                            <i class="fa-solid fa-users"></i>
                            <span>Сотрудники</span>
                        </a>
                    </li>
                    <li>
                        <a class="nav-link@(currentController=="Brigade" ? " active" : "")" asp-area="" asp-controller="Brigade" asp-action="Index">
                            <i class="fa-solid fa-people-group"></i>
                            <span>Бригады</span>
                        </a>
                    </li>
                    <li>
                        <a class="nav-link@(currentController=="Statistics" ? " active" : "")" asp-area="" asp-controller="Statistics" asp-action="Index">
                            <i class="fa-solid fa-chart-column"></i>
                            <span>Статистика</span>
                        </a>
                    </li>
                    <li>
                        <a class="nav-link@(currentController=="Installment" ? " active" : "")" asp-area="" asp-controller="Installment" asp-action="Index">
                            <i class="fa-solid fa-credit-card"></i>
                            <span>Рассрочки</span>
                        </a>
                    </li>
                }
                <li>
                    <a class="nav-link@(currentController=="Archive" ? " active" : "")" asp-area="" asp-controller="Archive" asp-action="Index">
                        <i class="fa-solid fa-box-archive"></i>
                        <span>Архив</span>
                    </a>
                </li>
                <li>
                    <a class="nav-link@(currentController=="Sklad" ? " active" : "")" asp-area="" asp-controller="Sklad" asp-action="Index">
                        <i class="fa-solid fa-warehouse"></i>
                        <span>Склад</span>
                    </a>
                </li>
            </ul>
            <div class="app-sidebar-footer">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="app-sidebar-user">
                        <a asp-controller="Account" asp-action="Profile"
                           class="text-decoration-none text-white-50 d-flex flex-column align-items-center"
                           title="Личный кабинет">
                            <i class="fa-solid fa-user-circle fa-lg mb-1"></i>
                            <span class="app-sidebar-user-name">@User.Identity.Name</span>
                        </a>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            <button type="submit"
                                    class="btn btn-sm btn-outline-light logout-btn d-flex align-items-center justify-content-center px-3 py-1"
                                    title="Выйти">
                                <i class="fa-solid fa-door-open"></i>
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="app-sidebar-user">
                        <a asp-controller="Account" asp-action="Login"
                           class="btn btn-sm btn-outline-light d-flex align-items-center gap-2 px-3 py-1"
                           title="Войти">
                            <i class="fa-solid fa-door-open"></i>
                            <span class="small">Вход</span>
                        </a>
                    </div>
                }
            </div>
        </aside>

        <div class="app-main">
            <header class="app-main-header">
            </header>
            <main role="main" class="app-main-content">
                @RenderBody()
            </main>
            <footer class="border-top footer text-muted bg-light mt-auto">
                <div class="container-fluid py-2 px-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="small">&copy; 2025 - DP_BurLida</span>
                        <a asp-area="" asp-controller="Home" asp-action="Privacy" class="btn btn-outline-secondary btn-sm">
                            Политика конфиденциальности
                        </a>
                    </div>
                </div>
            </footer>
        </div>
    </div>
    <environment include="Development">
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js" crossorigin="anonymous"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" referrerpolicy="no-referrer"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js" referrerpolicy="no-referrer"></script>
    </environment>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
