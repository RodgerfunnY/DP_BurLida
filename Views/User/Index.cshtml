@model IEnumerable<DP_BurLida.Data.ModelsData.UserModelData>

@{
    ViewData["Title"] = "Сотрудники";
}

<div class="content-card">
<h1>Сотрудники</h1>

<p>
    <a asp-action="Create" class="btn btn-outline-success" title="Добавить сотрудника">
        <i class="fas fa-user-plus"></i>
    </a>
</p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>
                Имя
            </th>
            <th>
                Фамилия
            </th>
            <th>
                Email
            </th>
            <th>
                Телефон
            </th>
            <th>
                Роль
            </th>
            <th>
                Подтвержден
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Surname)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Phone)
            </td>
            <td>
                @item.Role
            </td>
            <td>
                @(item.IsApproved ? "Да" : "Нет")
            </td>
            <td class="text-nowrap">
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning me-1" title="Редактировать">
                    <i class="fas fa-pen"></i>
                </a>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1" title="Подробности">
                    <i class="fas fa-eye"></i>
                </a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Удалить">
                    <i class="fas fa-trash"></i>
                </a>
            </td>
        </tr>
}
    </tbody>
</table>
</div>
